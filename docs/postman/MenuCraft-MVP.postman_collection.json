                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "description": "JWT token obtenido del login"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/products/:id",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "products",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "ID del platillo a eliminar"
                }
              ]
            },
            "description": "Eliminar un platillo (requiere autenticación)"
          },
          "response": []
