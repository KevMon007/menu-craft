              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "description": "JWT token obtenido del login"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tacos al Pastor\",\n  \"description\": \"Tacos tradicionales con carne marinada\",\n  \"price\": 9.00,\n  \"category\": \"Fuertes\",\n  \"available\": false\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/products/:id",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "products",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "ID del platillo a actualizar"
                }
              ]
            },
            "description": "Actualizar un platillo existente o cambiar su disponibilidad (requiere autenticación)"
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
