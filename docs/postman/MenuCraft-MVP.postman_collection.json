    {
      "name": "Products (Admin)",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "description": "JWT token obtenido del login"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tacos al Pastor\",\n  \"description\": \"Tacos tradicionales con carne marinada\",\n  \"price\": 8.50,\n  \"category\": \"Fuertes\",\n  \"available\": true,\n  \"imageUrl\": \"https://example.com/tacos.jpg\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/products",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Crear un nuevo platillo (requiere autenticación)"
          },
          "response": []
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "description": "JWT token obtenido del login"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/products",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Obtener todos los platillos del restaurante autenticado"
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
