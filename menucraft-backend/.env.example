# ============================================================
# MenuCraft SaaS - Variables de Entorno
# ============================================================
# Copia este archivo como .env y ajusta los valores.
# NUNCA subas .env al repositorio.
# ============================================================

# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Base de Datos (PostgreSQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=menucraft_user
DB_PASS=menucraft_password
DB_NAME=menucraft_db

# ─── Seguridad JWT ───────────────────────────────────────────
# IMPORTANTE: En producción, genera un valor aleatorio seguro:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTE_VALOR_POR_UNO_ALEATORIO_SEGURO
JWT_EXPIRES_IN=8h

# ─── Firebase Storage ────────────────────────────────────────
# Solo si vas a usar subida de imágenes a Firebase
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_STORAGE_BUCKET=tu-proyecto-firebase.appspot.com
